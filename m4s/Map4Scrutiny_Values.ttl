#############################
##                         ##
##     Contract types      ##
##                         ##
#############################

:ContratosPublicos a    skos:ConceptScheme;
  skos:prefLabel        "Termos para Descrição de Contratos Públicos"@pt;
  dct:creator           "Inês Lopes";
	dct:contributor       "Ana Alice Batista", "Óscar João Atanázio Afonso";
  dct:created           "2021-07-05"^^schema:Date;
  dct:source            <https://data.dre.pt/eli/dec-lei/18/2008/p/cons/20210521/pt/html>;
  skos:editoralNote     "Usado na descrição de recursos classificados como: <http://contsem.unizar.es/def/sector-publico/pproc#Contract> no âmbito legal português."@pt;
  rdf:seeAlso          <http://purl.org/cpv/2008/>;
  skos:hasTopConcept    :TipoContrato, :TipoProcedimento .

:TipoContrato a      skos:Concept;
  skos:prefLabel      "Tipos de Contratos Públicos"@pt;
  skos:definition     "Tipos de Contractos definidos nos artigos do Código da Contratação Pública e usados no portal <base.gov.pt>"@pt;
  skos:editoralNote   "Narrowers são usados para descrever valores da propriedade:  <http://purl.org/procurement/public-contracts#kind> no âmbito legal português.>"@pt;
  skos:inScheme       <http://purl.org/map4scrutiny-values#ContratosPublicos>;
  rdf:seeAlso         <https://raw.githubusercontent.com/opendatacz/public-contracts-ontology/master/schemes/contract-kinds.ttl>;
  skos:narrower       :BensMoveis, :Servicos, :ConcessaoObrasPublicas, :ConcessaoServicosPublicos, 
                      :Sociedade, :EmpreitadasObrasPublicas, :LocacaoBensMoveis .

:TipoProcedimento a      skos:Concept;
  skos:prefLabel      "Tipos de Contratos Públicos"@pt;
  skos:editoralNote   "Narrowers são usados para descrever valores da propriedade: <http://purl.org/procurement/public-contracts#procedureType> no âmbito legal português.>"@pt;
  skos:inScheme       <http://purl.org/map4scrutiny-values#ContratosPublicos>; 
  rdf:seeAlso         <https://raw.githubusercontent.com/opendatacz/public-contracts-ontology/master/schemes/procedure-types.ttl>; 
  skos:narrower       :AjusteDiretoRG, :ConsultaPrevia, :ConcursoPublico, :ConcursoLimitado, :ProcedimentoNegociacao, :DialogoConcorrencial,
                      :AcordoQuadro258, :AcordoQuadro259, :ParceriaInovacao, :DispBensMoveis, :Serviços, :ConcursoConcecao, :ConcursoIdeias .

:BensMoveis a skos:Concept;
  skos:prefLabel      "Aquisição de Bens Móveis"@pt;
  skos:definition       "Entende-se por aquisição de bens móveis o contrato pelo qual um contraente público compra bens móveis a um fornecedor. (Artigo 437º CCP)"@pt; 
  skos:broader        :TipoContrato .

:Servicos a skos:Concept;
  skos:prefLabel      "Aquisição de serviços"@pt;
  skos:definition     "Entende-se por aquisição de serviços o contrato pelo qual um contratante público adquire a prestação de um ou vários tipos de serviços mediante o pagamento de um preço. (Artigo 450º CCP)"@pt; 
  skos:broader        :TipoContrato;
  skos:closeMatch     <http://purl.org/procurement/public-contracts-kinds#Services> .

:ConcessaoObrasPublicas a skos:Concept;
  skos:prefLabel      "Concessão de Obras Públicas"@pt;
  skos:definition       "Contrato pelo qual o co-contratante se obriga à execução ou à conceção e execução de obras públicas, adquirindo em contrapartida o direito de proceder, durante um determinado período, à respetiva exploração, e, se assim estipulado, o direito ao pagamento de um preço. (Artigo 407º CCP)"@pt; 
  skos:broader      :TipoContrato .

:ConcessaoServicosPublicos a skos:Concept;
  skos:prefLabel      "Concessão de Serviços Públicos"@pt;
  skos:definition       "Entende-se por concessão de serviços públicos o contrato pelo qual o co-contratante se obriga a gerir, em nome próprio e sob sua responsabilidade, uma atividade de serviço público, durante um determinado período, sendo remunerado pelos resultados financeiros dessa gestão ou, diretamente, pelo contraente público.(Artigo 407º CCP)"@pt; 
  skos:broader      :TipoContrato .

:Sociedade a skos:Concept;
  skos:prefLabel      "Empreitadas de obras públicas"@pt;
  skos:definition       "Contrato oneroso que tenha por objeto quer a execução quer, conjuntamente, a conceção e a execução de uma obra pública que se enquadre nas subcategorias previstas no (Artigo 343º CCP)"@pt; 
  skos:broader      :TipoContrato .

:EmpreitadasObrasPublicas a skos:Concept;
  skos:prefLabel      "Locação de bens móveis"@pt;
  skos:definition       "Entende-se por locação de bens móveis o contrato pelo qual um locador se obriga a proporcionar a um contraente público o gozo temporário de bens móveis, mediante retribuição. (Artigo 431º CCP)"@pt; 
  skos:broader      :TipoContrato .

:LocacaoBensMoveis a skos:Concept;
  skos:prefLabel      "Sociedade"@pt;
  skos:definition       "O contrato de sociedade está sujeito à disciplina geral dos contratos, com as particularidades decorrentes da sua natureza de contrato de fim comum e institucional. Criação e funcionamento de uma organização – a sociedade-instituição –, a qual funciona segundo um conjunto de regras traçadas no contrato, como ente dinâmico e mutável e se norteia por um escopo a que é destinada (o objeto social: é, pois um contrato de organização).."@pt; 
  skos:broader      :TipoContrato .

:AjusteDiretoRG a skos:Concept;
  skos:prefLabel      "Ajuste Direto Regime Geral"@pt;
  skos:definition       "O ajuste direto é o procedimento em que a entidade adjudicante convida diretamente uma entidade à sua escolha a apresentar proposta. (Artigo 112º CCP)"@pt; 
  skos:broader      :TipoProcedimento;
  skos:closeMatch   proctypes:AwardWithoutPriorPublication . 

:ConsultaPrevia a skos:Concept;
  skos:prefLabel      "Consulta Prévia"@pt;
  skos:definition     "A consulta prévia é o procedimento em que a entidade adjudicante convida diretamente pelo menos três entidades à sua escolha a apresentar proposta, podendo com elas negociar os aspetos da execução do contrato a celebrar. (Artigo 112º CCP)"@pt; 
  skos:broader      :TipoProcedimento . 

:ConcursoPublico a skos:Concept;
  skos:prefLabel      "Concurso público"@pt;
  skos:definition     "O concurso público é publicitado no Diário da República, através de anúncio conforme modelo aprovado por portaria dos membros do Governo responsáveis pela edição do Diário da República e pelas áreas das finanças e das obras públicas. (Artigo 130º CCP)"@pt; 
  skos:broader      :TipoProcedimento . 

:ConcursoLimitado a skos:Concept;
  skos:prefLabel      "Concurso limitado por prévia qualificação"@pt;
  skos:definition       "O concurso limitado por prévia qualificação rege-se, com as necessárias adaptações, pelas disposições que regulam o concurso público. É composto por duas fases: a) Apresentação das candidaturas e qualificação dos candidatos; b) Apresentação e análise das propostas e adjudicação. (Artigos 162º e 163º do CCP)"@pt; 
  skos:broader      :TipoProcedimento . 

:ProcedimentoNegociacao a skos:Concept;
  skos:prefLabel      "Procedimento de Negociação"@pt;
  skos:definition       "O procedimento de negociação rege-se, com as necessárias adaptações, pelas disposições que regulam o concurso limitado por prévia qualificação. É composto por quatro fases: a) Apresentação das candidaturas e qualificação dos candidatos; b) Apresentação e análise das versões iniciais das propostas; c) Negociação das propostas; d) Análise das versões finais das propostas e adjudicação."@pt; 
  skos:broader      :TipoProcedimento . 

:DialogoConcorrencial a skos:Concept;
  skos:prefLabel     "Diálogo Concorrencial"@pt;
  skos:definition    "O procedimento de diálogo concorrencial rege-se, com as necessárias adaptações, pelas disposições que regulam o concurso limitado por prévia qualificação. A entidade adjudicante não pode recorrer a um leilão eletrónico nem adotar uma fase de negociações e é composto pelas seguintes fases: a) Apresentação das candidaturas e qualificação dos candidatos; b) Apresentação das soluções e diálogo com os candidatos qualificados; c) Apresentação e análise das propostas e adjudicação."@pt; 
  skos:broader      :TipoProcedimento;
  skos:closeMatch   proctypes:CompetitiveDialogue . 
                      
:AcordoQuadro258 a skos:Concept;
  skos:prefLabel      "Ao abrigo de acordo-quadro (art.º 258.º)"@pt;
  skos:definition       "Celebração de contratos ao abrigo de acordos-quadro cujos termos abranjam todos os seus aspetos submetidos à concorrência"@pt; 
  skos:broader      :TipoProcedimento . 

:AcordoQuadro259 a skos:Concept;
  skos:prefLabel      "Ao abrigo de acordo-quadro (art.º 259.º)"@pt;
  skos:definition       "Celebração de contratos ao abrigo de acordos-quadro cujos termos não abranjam todos os seus aspetos submetidos à concorrência"@pt; 
  skos:broader      :TipoProcedimento . 

:ParceriaInovacao a skos:Concept;
  skos:prefLabel      "Parceria Para a Inovação"@pt;
  skos:definition       "É usada quando se pretende um bem ou serviço ainda não existente no mercado. É composta por três fases: a) Fase de apresentação das candidaturas, podendo a respetiva seleção incluir a qualificação dos candidatos quando se trate do desenvolvimento de projetos dotados de especial complexidade; b) Fase de apresentação de propostas de projetos de investigação e desenvolvimento; c) Fase de análise das propostas de projetos de investigação e celebração da parceria."@pt; 
  skos:broader      :TipoProcedimento . 

:DispBensMoveis a skos:Concept;
  skos:prefLabel      "Disponibilização de Bens Móveis"@pt;
  skos:definition       "Os bens móveis de que os serviços não careçam para o exercício das suas competências são disponibilizados, com vista à sua reafetação a outros serviços ou à sua alienação."@pt; 
  skos:broader      :TipoProcedimento . 

:Serviços a skos:Concept;
  skos:prefLabel      "Serviços Sociais e Outros Serviços Específicos"@pt;
  skos:definition       "Os contratos públicos de valor igual ou inferior ao limiar de € 750 000, que tenham por objeto a aquisição de serviços sociais ou de outros serviços específicos."@pt; 
  skos:broader      :TipoProcedimento . 

:ConcursoConcecao a skos:Concept;
  skos:prefLabel      "Concurso de Conceção Simplificado"@pt;
  skos:definition       "O órgão competente da entidade adjudicante seleciona um ou mais trabalhos de conceção, consoante o número fixado nos termos de referência do concurso, de acordo com o teor e as conclusões do relatório final, nomeadamente com as deliberações vinculativas tomadas pelo júri."@pt; 
  skos:broader      :TipoProcedimento . 

:ConcursoIdeias a skos:Concept;
  skos:prefLabel      "Concurso de Ideias Simplificado"@pt;
  skos:definition       "Concursos de ideias destinados a adquirir uma ou várias propostas de ideias, remuneradas através da atribuição de um prémio apropriado."@pt; 
  skos:broader      :TipoProcedimento . 


#############################
##                         ##
##  Regime de Propriedade  ##
##                         ##
#############################

:PropertyRegimen a    skos:ConceptScheme;
  skos:prefLabel       "Regimes de Propriedade Matrimonial de acordo com a Lei Portuguesa"@pt;
  dct:creator          "Inês Lopes";
	dct:contributor      "Ana Alice Batista", "Óscar João Atanázio Afonso";
  dct:created          "2021-07-05"^^schema:Date;
  skos:editoralNote    "Usado como um valor para a propriedade: <http://purl.org/map4scrutiny-core#propertyRegimen> no âmbito legal português. "@pt, "Used as a value for the property: <http://purl.org/map4scrutiny-core#propertyRegimen> under the scope of the Portuguese law. "@en;
  skos:source          <https://www.eurofinesco.com/>;
  skos:hasTopConcept   :ComAdquiridos, :ComGeralBens, :SepBens, :Outros
  .

:ComAdquiridos a skos:Concept;
  skos:prefLabel        "Community Property"@en, "Comunhão de Adquiridos"@pt;
  skos:definition       "Assets acquired over the course of marriage are consideres to be community property of the spouses as one. Assets individually acquired prior to the marriage or after the marriage by succession or gift are individual."@en, 
                        "Bens adquiridos após no matrimónio são considerados bens do casal enquanto entidade comum. Bens adquiridos individualmente antes do matrimónio ou após do mesmo por oferta ou sucessão são considerados individuais."@pt; 
  .

:ComGeralBens a skos:Concept;
  skos:prefLabel      "Common property"@en, "Comunhão Geral de Bens"@pt;
  skos:definition     "All present and future assets are considered property of the couple."@en,
                      "Todos os bens existentes e que virão a ser adquiridos são propriedade do casal."@pt
                      .

:SepBens a skos:Concept;
  skos:prefLabel      "Separate assets"@en, "Separação Geral de Bens"@pt;
  skos:definition     "There are no common assets. All property is individual to each spouse."@en,
                      "Não há bens comuns. Toda a propriedade pertence a cada elemento do casal individualmente."@pt
                      .

:Outros a skos:Concept;
  skos:prefLabel      "Other"@en, "Outro"@pt;
  skos:definition     "Other options taken by the couple within the limits of the Portuguese law."@en, "Outra opção definida pelo casal dentro dos limites da lei portuguesa."@pt
  .
