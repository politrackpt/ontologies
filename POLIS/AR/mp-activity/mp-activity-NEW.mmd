    mpact:RA["mpact:RA"] -.-> PET

    PAct(mpact:ParliamentaryActivity) -- core:belongsToLegislature --> Leg
    PAct -.-> Activity(prov:Activity)
    mpact:AGP["mpact:AGP"] -.-> PAct
    mpact:CER["mpact:CER"] -.-> PAct
    mpact:DEB["mpact:DEB"] -.-> PAct
    mpact:DES["mpact:DES"] -.-> PAct
    mpact:DPO["mpact:DPO"] -.-> PAct
