@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix ocd: <http://dati.camera.it/ocd/> .
@prefix m4s: <https://purl.org/map4scrutiny-core#> .
@prefix schema:	<https://schema.org/> .
@prefix polis-ini: <http://purl.org/polis/ar/initiatives#> .
@prefix : <http://purl.org/polis/ar/core#> .

@base <http://purl.org/polis/ar/core#> .

:	
	a                           	<http://purl.org/vocommons/voaf#Vocabulary> , owl:Ontology ;
	dct:title                   	"Portuguese Political Structures Ontology";
	dct:description             	"";
	dct:creator                 	"Tiago Ribeiro de Sá Cruz", "João Miguel da Silva Lourenço";
	dct:contributor                 "Mariana Curado Malta", "João Bispo";
    dct:issued                 		""^^schema:Date;
	dct:license                 	<http://creativecommons.org/publicdomain/zero/1.0/> ;
	vann:preferredNamespacePrefix   "polis-core:" ;
	vann:preferredNamespaceUri      "http://purl.org/polis/ar/core#" ;
	owl:versionInfo					"1.0";
    rdfs:comment                    """The objective of the POLIS ontology is to (...)""" ;
    dcterms:bibliographicCitation ""@en ;
    dcterms:created ""^^xsd:date ;
    dcterms:modified ""^^xsd:date ;
    dcterms:language "en", "pt" ;
.

#################################################################
#    Classes
#################################################################

:ParliamentaryGroup rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
    rdfs:label "Parliamentary Group"@en, "Grupo Parlamentar"@pt ;
    rdfs:comment "A parliamentary group that exists in a parliament during a legislature, containing elected MPs"@en,
        "Um grupo parlamentar que existe num parlamento durante uma legislatura, que contém MPs eleitos"@pt .

:Party rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
    rdfs:label "Party"@en, "Partido"@pt ;
    rdfs:comment "A political party"@en, "Um partido político"@pt ;
    rdfs:subClassOf <http://www.w3.org/ns/org#Organization> .

#################################################################
#    Data properties
#################################################################

:hasIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://w3id.org/nfdi4ing/metadata4ing#identifier> ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
    rdfs:label "has identifier"@en, "tem o identificador"@pt ;
    rdfs:comment "An unique identifier to identify something"@en, "Um identificar único para identificar algo"@pt ;
    rdf:type owl:FunctionalProperty .

:hasName rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
    rdfs:label "has name"@en, "tem o nome"@pt ;
    rdfs:comment "A name"@en, "Um nome"@pt ;
    rdfs:range xsd:string .

#################################################################
#    Object properties
#################################################################

:belongsToLegislature rdf:type owl:ObjectProperty ,
            owl:FunctionalProperty ;
            rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
            rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( ocd:mandatoCamera
                                        ocd:sessioneLegislatura
                                        polis-ini:Initiative
                                        :ParliamentaryGroup
                                        )
                        ] ;
            rdfs:range ocd:legislatura .

:isOfParty rdf:type owl:ObjectProperty ,
             owl:FunctionalProperty ;
            rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
    rdfs:domain :ParliamentaryGroup ;
    rdfs:range :Party .


:belongsToLegislativeSession rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/core#> ;
     rdfs:domain polis-core:Initiative ;
     rdfs:range ocd:sessioneLegislatura .