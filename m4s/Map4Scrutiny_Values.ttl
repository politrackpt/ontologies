:ComissoesParlamentares a skos:ConceptScheme;
  skos:prefLabel "Comissões do Parlamento Português"@pt;
  dct:creator    "Inês Lopes";
	dct:contributor  "Ana Alice Batista", "Óscar João Atanázio Afonso";
  dct:created "2021-07-05"^^schema:Date;
  dct:source  <https://www.parlamento.pt/>;
  skos:editoralNote "Usado como um valor para a propriedade: <http://purl.org/map4scrutiny-core#parliamentaryComissions> no âmbito legal português.";
  skos:hasTopConcept  :Comissao, :SubComissao, :Grupo;
.

:Comissao a skos:Concept;
  skos:prefLabel "Comissão"@pt;
  skos:narrower :CERC, :CTSS, :CTED, :CS , :CPIPRNBIFR , :COF , :CNECP , :CEVPDE, :CEPII2017 , 
                :CEIOPH , :CECJD , :CEAMCOVID19 , :CDN , :CCC , :CAPMADPL, :CAM , :CAEOT , :CAE , :CACDLG 
  .

:SubComissao a skos:Concept;
  skos:prefLabel "Subcomissão"@pt;
  skos:narrower  :SRSAP, :SIND 
  .

:Grupo a skos:Concept;
  skos:prefLabel "Grupo de Trabalho"@pt;
  skos:narrower :GT-VCN, :GT-TAS, :GT-SM, :GT-RI, :GT-RCIP, :GT-PMA, :GT-PJL-ER, :GT-PJL-DG-BC, :GT-PJ, :GT-PIDDAT, :GT-LBC, :GT-JPDH2020, :GT-JPABMEP2020,
                :GT-IVPCA, :GT-EIE, :GT-EI, :GT-DPD, :GT-DC, :GT-CTSDT, :GT-ASC, :GT-ARCPAS, :GT-APRAEP, :GT-ACTFS, :GT-A3CDN, :GT-A11CAEOT, :GT-A10CTSS
  .

