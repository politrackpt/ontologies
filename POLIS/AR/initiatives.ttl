@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix ocd: <http://dati.camera.it/ocd/> .
@prefix m4s: <https://purl.org/map4scrutiny-core#> .
@prefix schema:	<https://schema.org/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix : <http://purl.org/polis/ar/initiatives#> .

@base <http://purl.org/polis/ar/initiatives#> .

:	
	a                           	<http://purl.org/vocommons/voaf#Vocabulary> , owl:Ontology ;
	dct:title                   	"Portuguese Political Structures Ontology";
	dct:description             	"";
	dct:creator                 	"Tiago Ribeiro de Sá Cruz", "João Miguel da Silva Lourenço";
	dct:contributor                 "Mariana Curado Malta", "João Bispo";
    dct:issued                 		""^^schema:Date;
	dct:license                 	<http://creativecommons.org/publicdomain/zero/1.0/> ;
	vann:preferredNamespacePrefix   "polis-ini:" ;
	vann:preferredNamespaceUri      "http://purl.org/polis/ar/initiatives#" ;
	owl:versionInfo					"1.0";
    dct:description                    """The objective of the POLIS ontology is to (...)""" ;
    dcterms:bibliographicCitation ""@en ;
    dcterms:created ""^^xsd:date ;
    dcterms:modified ""^^xsd:date ;
    dcterms:language "en", "pt" ;
.

#################################################################
#    Classes
#################################################################

:Commission rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
    rdfs:label "Comissão"@pt ,
               "Commission"@en ;
	dct:description ""@pt , ""@en .

:RegionalLegislativeAssembly rdf:type owl:Class ;
	rdfs:label "Assembleia Legislativa Regional"@pt ,"Regional Legislative Assembly"@en ;
	dct:description ""@pt , ""@en ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

:CitizenGroup rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "Citizen Group"@en ,
               "Grupo de Cidadãos"@pt .

:Initiative rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "Initiative"@en ,
               "Iniciativa"@pt ;
    rdfs:subClassOf ocd:atto .

:EuropeanInitiative rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "European Initiative"@en ,
               "Iniciativa Europeia"@pt ;
    rdfs:subClassOf ocd:atto .

:ConstitutionalRevisionProject rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Uma proposta para amendar ou rever a Constituição, que requer uma maioria de dois terços dos votos"@pt , "A proposal to amend or revise the Constitution, which requires a two thirds majority vote"@en ;
    rdfs:label "Constitutional Revision Project"@en ,
               "Projeto de Revisão Constitucional"@pt ;
    rdfs:subClassOf :Initiative .

:DeliberationProject rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "Deliberation Project"@en ,
               "Projeto de Deliberação"@pt ;
    rdfs:subClassOf :Initiative .

:LawProject rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Uma proposta legislativa apresentada por um deputado, um grupo parlamentar ou por um grupo de cidadãos, destinada a tornar-se lei após debate, alteração e aprovação no Parlamento"@pt, 
		"A legislative proposal submitted by MP, PG or citizen group, intended to become law after debate, amendment, and approval in Parliament"@en ;
    rdfs:label "Law Project"@en ,
               "Projeto de Lei"@pt ;
    rdfs:subClassOf :Initiative .


:LawProposal rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Uma proposta legislativa apresentada pelo Governo ou pelas Assembleias Legislativas Regionais. Funciona de forma semelhante a um projeto de lei, mas difere na sua origem"@pt,
		"A legislative proposal submitted by the Government or Regional Legislative Assemblies. Functions similarly to a Law Project but differs by origin"@en ;
    rdfs:label "Law Proposal"@en ,
               "Proposta de Lei"@pt ;
    rdfs:subClassOf :Initiative .

:ParliamentaryAppreciation rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "Parliamentary Appreciation"@en ,
               "Apreciação Parlamentar"@pt ;
    rdfs:subClassOf :Initiative .

:ParliamentaryInquiry rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Um inquérito iniciado pelo Parlamento para examinar as atividades do governo ou da função pública, recolher provas e elaborar um relatório com conclusões ou recomendações. "@pt , 
		"An investigation initiated by Parliament to examine government or public administration activities, gather evidence, and produce a report with conclusions or recommendations. "@en ;
    rdfs:label "Parliamentary Inquiry"@en ,
               "Inquérito Parlamentar"@pt ;
    rdfs:subClassOf :Initiative .

:PopularReferendumInitiative rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Uma iniciativa de referendo de iniciativa popular que requer, pelo menos, 60000 assinaturas de eleitores recenseados, residentes no território nacional."@pt , 
		"A citizen-driven referendum initiative that requires at least 60000 signatures of registered voters, registered in national territory."@en ;
    rdfs:label "Popular Referendum Initiative"@en ,
               "Iniciativa Popular de Referendo"@pt ;
    rdfs:subClassOf :Initiative .

:Ratification rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , ""@en ;
    rdfs:label "Ratification"@en ,
               "Ratificação"@pt ;
    rdfs:subClassOf :Initiative .

:ResolutionProject rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Iniciativa apresentada por deputados ou por grupos parlamentares, que não assume a forma de lei após a sua aprovação e que é, na sua maioria, de natureza política."@pt , 
		"Initiative by MPs or parliamentary groups, which does not take the form of law once approved and is mostly of political nature."@en ;
    rdfs:label "Resolution Project"@en ,
               "Projeto de Resolução"@pt ;
   rdfs:subClassOf :Initiative .

:ResolutionProposal rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Iniciativa governamental apresentada à Assembleia da República para apreciação e aprovação de acordos e tratados internacionais."@pt , 
		"Government initiative presented to the Assembly of the Republic for appreciation and approval of international agreements and treaties."@en ;
    rdfs:label "Resolution Proposal"@en ,
               "Proposta de Resolução"@pt ;
    rdfs:subClassOf :Initiative .

:RulesOfProcedureProject rdf:type owl:Class ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Uma proposta para criar ou alterar as normas e procedimentos internos que regem a organização e a atividade parlamentares."@pt , 
		"A proposal to create or amend the internal rules and procedures governing parliamentary organization and activity."@en ;
    rdfs:label "Rules Of Procedure Project"@en ,
               "Projeto de Regimento"@pt ;
    rdfs:subClassOf :Initiative .

:Content rdf:type owl:Class ;
	dct:description "Define todo o conteúdo de uma iniciativa"@pt , 
		"Defines the content of an initiative"@en ;
    rdfs:label "Content"@en ,
               "Conteúdo"@pt ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

# :Annex a owl:Class ;
#     dct:description "Um anexo é um documento que complementa uma iniciativa ou um evento, fornecendo conteúdo adicional não estruturado."@pt , 
#         "An Annex is a documental entity that supplements an Initiative or Event by providing additional unstructured content."@en ;
#     rdfs:label "Annex"@en ,
#             "Anexo"@pt ;
#     rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
#     rdfs:subClassOf ocd:documenti .

:ChangeProposal a owl:Class ;
    dct:description "Uma proposta de alteração é um documento formal de alteração associado a uma iniciativa, representando uma proposta estruturada para modificar o seu conteúdo durante o processo legislativo."@pt , 
        "A Change Proposal is a formal amendment entity associated with an Initiative, representing a structured proposal to modify its content during the legislative process."@en ;
    rdfs:label "Change Proposal"@en ,
            "Proposta de Alteração"@pt ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

:Petition a owl:Class ;
    dct:description "Uma petição é um pedido formal apresentado no âmbito parlamentar por um grupo de cidadãos e registado numa legislatura e sessão legislativa específicas. Os proponentes podem ter a petição em consideração e apresentar iniciativas com base nos pedidos nela contidos."@pt , 
        "A Petition is a formal request submitted within the parliamentary framework by a group of citizens and registered within a specific Legislature and Legislative Session. Proponents can take the petition into account and propose initiatives based on the requests of the petition."@en ;
    rdfs:label "Petition"@en ,
            "Petição"@pt ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

:Event a owl:Class ;
    dct:description "Um evento representa um acontecimento no ciclo de vida de uma iniciativa. Corresponde a uma fase ou ação específica no ciclo de vida da iniciativa, como a fase de apresentação, as revisões da comissão, os momentos de votação ou outras etapas formais."@pt , 
        "An Event represents an occurrence within the lifecycle of an Initiative. It corresponds to a specific phase or action in the initiative lifecycle, such as the introduction phase, committee reviews, voting moments, or other formal steps."@en ;
    rdfs:label "Event"@en ,
            "Evento"@pt ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

#################################################################
#    Data properties
#################################################################

:title rdf:type owl:DatatypeProperty ;
	dct:description "Define o título de uma iniciativa"@pt , 
		"Defines the title of an initiative"@en ;
    rdfs:label "has title"@en ,
               "tem título"@pt ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
    rdfs:domain [ rdf:type owl:Class ;
      owl:unionOf ( :Initiative
                    :Petition
                  )
    ] ;
    rdfs:range xsd:string .

:link rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o link onde está hosteado no website do parlamento Português o documento"@pt , 
		"Defines the link in the Portuguese parliament's website where the document is hosted"@en ;
    rdfs:label "hosted in link"@en ,
               "hosteado no link"@pt ;
    rdfs:domain bibo:Document ;
    rdfs:range xsd:string .

:text rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o conteúdo textual da iniciativa"@pt , 
		"Defines the textual content of the initiative"@en ;
    rdfs:label "has text"@en ,
               "contém texto"@pt ;
    rdfs:domain :Content ;
    rdfs:range xsd:string .

:parliamentaryName rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o nome parlamentar de um MP durante uma legislatura"@pt , 
		"Defines the parliamentarian name of a MP during a legislature"@en ;
    rdfs:label "has parliamentary name"@en ,
               "tem nome parlamentar"@pt ;
    rdfs:domain ocd:mandatoCamera ;
    rdfs:range xsd:string .

:changeProposalType rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o tipo de uma proposta de alteração"@pt , 
		"Defines the type of a change proposal"@en ;
    rdfs:label "change proposal type"@en ,
               "tipo de proposta de alteração"@pt ;
    rdfs:domain :ChangeProposal ;
    rdfs:range xsd:string .

:proposedBy rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o proponente de uma proposta de alteração"@pt , 
		"Defines the proponent of a change proposal"@en ;
    rdfs:label "is proposed by"@en ,
               "é proposta por"@pt ;
    rdfs:comment "This term is used when the data does not specify exactly which group or individual proposed the amendment. When we know exactly who it is, we should use the term 'proposed by a parliamentary group' or 'proposed by a member of parliament'."@en ,
        "Este termo é utilizado quando os dados não especificam exatamente qual o grupo ou indivíduo que propôs a alteração. Quando sabemos exatamente de quem se trata, devemos utilizar o termo 'proposto por um grupo parlamentar' ou 'proposto por um deputado'."@pt ;
    rdfs:domain :ChangeProposal ;
    rdfs:range xsd:string .

:typeId rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o id do tipo de evento"@pt , 
		"Defines the id of the type of the event"@en ;
    rdfs:label "has event type id"@en ,
               "tem o id de tipo de evento"@pt ;
    rdfs:domain :Event ;
    rdfs:range xsd:int .

:eventType rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o tipo de evento"@pt , 
		"Defines the type of event"@en ;
    rdfs:label "has event type"@en ,
               "tem o tipo de evento"@pt ;
    rdfs:domain :Event ;
    rdfs:range xsd:string .

:observation rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Observações feitas à iniciativa durante um evento"@pt , 
		"Observations done to the initiative during an event"@en ;
    rdfs:label "has observation"@en ,
               "tem observação"@pt ;
    rdfs:domain :Event ;
    rdfs:range xsd:int .

:result rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o resultado de uma votação"@pt , 
		"Defines the result of a vote"@en ;
    rdfs:label "has result"@en ,
               "tem resultado"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range xsd:string .

:unanimous rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define se o resultado de uma votação é unânime"@pt , 
		"Defines if the result of a vote is unanimous"@en ;
    rdfs:label "is unanimous"@en ,
               "é unânime"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range xsd:boolean .

:reunionNumber rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o número da reunião em que a votação ocorreu"@pt , 
		"Defines the number of the reunion in which the vote occurred"@en ;
    rdfs:label "has reunion number"@en ,
               "tem número da reunião"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range xsd:int .

:reunionType rdf:type owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o tipo da reunião em que a votação ocorreu"@pt , 
		"Defines the type of the reunion in which the vote occurred"@en ;
    rdfs:label "has reunion type"@en ,
               "tem reunião do tipo"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range xsd:string .

#################################################################
#    Object properties
#################################################################

:hasAuthor rdf:type owl:ObjectProperty ;
	dct:description "Define o(s) autor(es) (MP) de uma iniciativa"@pt , 
		"Defines the author(s) (MP) of an initiative"@en ;
    rdfs:label "has author"@en ,
               "tem autor(a)"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range m4s:Parliamentarian ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> .

:hasProponent rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Define o(s) proponente(s) de uma iniciativa"@pt , 
		"Defines the proponent(s) of an initiative"@en ;
    rdfs:label "has proponent"@en ,
               "tem proponente"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range [ rdf:type owl:Class ;
      owl:unionOf ( ocd:governo
                    m4s:Parliamentarian
                    :CitizenGroup
                    :Commission
                    polis-core:ParliamentaryGroup
                    :RegionalLegislativeAssembly
                  )
    ] .

:ledTo rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa a outras que a original levou a serem criadas"@pt , 
		"Relates an initiative to other initiatives the original led to its creation"@en ;
    rdfs:label "led to"@en ,
               "levou a"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range :Initiative .


:grewOutOf rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa a iniciativas que levaram à sua origem, incluindo iniciativas europeias"@pt , 
		"Relates an initiative to to other initiatives that it grew out of, including european initiatives"@en ;
    rdfs:label "grew out of"@en ,
               "teve origem em"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( :EuropeanInitiative
                                :Initiative
                              )
                ] .

:happensJointlyWithInitiative rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Iniciativas em que o mesmo evento decorreu em conjunto com a iniciativa deste evento"@pt , 
		"Initiatives that had the same event happening jointly with the initiative from this event"@en ;
    rdfs:label "happens jointly with initiative"@en ,
               "acontece em conjunto com iniciativa"@pt ;
    rdfs:domain :Event ;
    rdfs:range :Initiative .

:discussedJointlyWith rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Processos de contas públicas ou petições discutidas em conjunto com um evento"@pt , 
		"Public accout proceedings or petitions discussed jointly with an event"@en ;
    rdfs:label "discussed jointly with"@en ,
               "discutido em conjunto com"@pt ;
    rdfs:domain :Event ;
    rdfs:range :Petition .

:hasAnnex rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa ou um evento a um documento em anexo"@pt , 
		"Relates an initiative or event to a document in annex"@en ;
    rdfs:label "has annex"@en ,
               "tem anexo"@pt ;
    rdfs:domain [ rdf:type owl:Class ;
                  owl:unionOf ( :Event
                                :Initiative
                              )
                ] ;
    rdfs:range bibo:Document .

:hasContent rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa ao seu conteúdo textual"@pt , 
		"Relates an initiative to its textual content"@en ;
    rdfs:label "has content"@en ,
               "tem conteúdo"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range bibo:Document .

:receivedAppeal rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , 
		""@en ;
    rdfs:label "received appeal"@en ,
               ""@pt ;
    rdfs:domain :Event ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( polis-core:ParliamentaryGroup
                                m4s:Parliamentarian
                              )
                ] .

:receivedChangeProposal rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description ""@pt , 
		""@en ;
    rdfs:label "received change proposal"@en ,
               "recebeu proposta de alteração"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range :ChangeProposal .

:hasRelatedPetition rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa a petições levou em conta durante a sua formulação, estando então relacionada a esta"@pt , 
		"Relates an initiative to petitions that it took into account during its formulation, and which is therefore related to it"@en ;
    rdfs:label "has related petition"@en ,
               "tem petição relacionada"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range :Petition .

:hasEvent rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma iniciativa a eventos que ocorreram ao longo do seu ciclo de vida"@pt , 
		"Relates an initiative to events that occurred during its lifecycle"@en ;
    rdfs:label "has event"@en ,
               "tem o evento"@pt ;
    rdfs:domain :Initiative ;
    rdfs:range :Event .

:hasVoteInFavourFrom rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma votação aos MPs e grupos parlamentares que votaram a favor"@pt , 
		"Relates a vote to the MPs and parliamentary groups that voted in favor"@en ;
    rdfs:label "has vote in favour from"@en ,
               "tem voto a favor de"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( polis-core:ParliamentaryGroup
                                m4s:Parliamentarian
                              )
                ] .

:hasVoteAgainstFrom rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma votação aos MPs e grupos parlamentares que votaram contra"@pt , 
		"Relates a vote to the MPs and parliamentary groups that voted against"@en ;
    rdfs:label "has vote against from"@en ,
               "tem voto contra de"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( polis-core:ParliamentaryGroup
                                m4s:Parliamentarian
                              )
                ] .

:hasAbstentionFrom rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma votação aos MPs e grupos parlamentares que se absteram de votar"@pt , 
		"Relates a vote to the MPs and parliamentary groups that abstained from the vote"@en ;
    rdfs:label "has abstention from"@en ,
               "tem abstenção de"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( polis-core:ParliamentaryGroup
                                m4s:Parliamentarian
                              )
                ] .

:hasAbsent rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma votação aos MPs que estiveram ausentes"@pt , 
		"Relates a vote to MPs who were absent"@en ;
    rdfs:label "has absent"@en ,
               "tem ausente"@pt ;
    rdfs:domain ocd:votazione ;
    rdfs:range m4s:Parliamentarian .

:hasVote rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona um evento de uma iniciativa a uma votação que ocorreu durante o mesmo"@pt , 
		"Relates an event of an initiative to a vote that occurred during it"@en ;
    rdfs:label "has vote"@en ,
               "tem a votação"@pt ;
    rdfs:domain :Event ;
    rdfs:range ocd:votazione .

:proposedByParliamentaryGroup rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma proposta de alteração ao grupo parlamentar que a submeteu"@pt , 
		"Relates a change proposal to the parliamentary group who submitted it"@en ;
    rdfs:label "proposed by parliamentary group"@en ,
               "proposta pelo grupo parlamentar"@pt ;
    rdfs:domain :ChangeProposal ;
    rdfs:range polis-core:ParliamentaryGroup .

:proposedByParliamentarian rdf:type owl:ObjectProperty ;
    rdfs:isDefinedBy <http://purl.org/polis/ar/initiatives#> ;
	dct:description "Relaciona uma proposta de alteração ao deputado que a submeteu"@pt , 
		"Relates a change proposal to the parliamentarian who submitted it"@en ;
    rdfs:label "proposed by parliamentarian"@en ,
               "proposta pela/o deputada/o"@pt ;
    rdfs:domain :ChangeProposal ;
    rdfs:range m4s:Parliamentarian .