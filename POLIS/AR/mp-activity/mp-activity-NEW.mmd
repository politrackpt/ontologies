    mpact:INI["mpact:INI"] -.-> PAct
    mpact:ITG["mpact:ITG"] -.-> PAct
    mpact:MOC["mpact:MOC"] -.-> PAct
    mpact:OEX["mpact:OEX"] -.-> PAct
    mpact:PEC["mpact:PEC"] -.-> PAct
    mpact:PEG["mpact:PEG"] -.-> PAct
    mpact:PET["mpact:PET"] -.-> PAct
    mpact:PII["mpact:PII"] -.-> PAct
    mpact:POR["mpact:POR"] -.-> PAct
    mpact:PRC["mpact:PRC"] -.-> PAct
    mpact:PRG["mpact:PRG"] -.-> PAct
    mpact:PUE["mpact:PUE"] -.-> PAct
    mpact:REP["mpact:REP"] -.-> PAct
    mpact:RSI["mpact:RSI"] -.-> PAct
    mpact:SES["mpact:SES"] -.-> PAct
    mpact:VOT["mpact:VOT"] -.-> PAct

    FPG(mpact:FriendshipParliamentaryGroup) -- core:belongsToLegislature --> Leg
    FPG -.-> F(foaf:Group)

    PA(mpact:PublicAccount) -- core:belongsToLegislature --> Leg

    Delegation(mpact:Delegation) -.-> F
    Delegation -- core:belongsToLegislature --> Leg
    Delegation -- core:belongsToLegislativeSession --> LegSession

    PD(mpact:PermanentDelegation) -.-> Delegation
    PD -- mpact:hasPermanentDelegationMeeting --> PDM(mpact:PermanentDelegationMeeting)

    TD(mpact:TemporaryDelegation) -.-> Delegation
    TD -- sem:hasPlace --> Place(sem:Place)
    TD -- mpact:hasDelegationScope --> DegS(mpact:DelegationScope)

    PDM -.-> dbo:Meeting
    PDM -- sem:hasPlace --> Place

    mpact:National["mpact:National"] -.-> DegS
    mpact:International["mpact:International"] -.-> DegS

    YPA(mpact:YouthParliamentActivity) -- mpact:heldAt --> School(dbo:School)
    YPA -- mpact:inConstituency --> core:Constituency
    YPA --core:belongsToLegislature -->	Leg
    YPA -.-> Activity

    School -- mpact:isSchoolType --> SchoolT(mpact:SchoolType)
    mpact:Basic["mpact:Basic"] -.-> SchoolT
    mpact:Secondary["mpact:Secondary"] -.-> SchoolT

    ComissionAct(mpact:CommissionActivity) -.-> PAct
    ComissionAct -- core:belongsToLegislature --> Leg
    ComissionAct -- mpact:relatedCommission --> core:Commission

    Audition(mpact:Audition) -.-> ComissionAct
    Audition -- prov:wasAssociatedWith --> ThirdP(mpact:ThirdPartyEntity)

    ThirdP -.-> prov:Agent

    Hearing("mpact:Hearing") -.-> ComissionAct
    Hearing -- prov:wasAssociatedWith --> ThirdP

    Event(mpact:Event) -.-> ComissionAct

    mpact:Debate["mpact:Debate"] -.-> Event
    mpact:Cerimony["mpact:Cerimony"] -.-> Event
    mpact:Conference["mpact:Conference"] -.-> Event
    mpact:Others["mpact:Others"] -.-> Event
    mpact:Visit["mpact:Visit"] -.-> Event

