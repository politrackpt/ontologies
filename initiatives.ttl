@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix ocd: <http://dati.camera.it/ocd/> .
@prefix : <> .

:	
	a                           	<http://purl.org/vocommons/voaf#Vocabulary> , owl:Ontology ;
	dct:title                   	"";
	dct:description             	"";
	dct:creator                 	"Tiago Ribeiro de Sá Cruz";
	dct:contributor                 "Mariana Curado Malta", "João Bispo";
    dct:issued                 		""^^schema:Date;
	dct:license                 	<http://creativecommons.org/publicdomain/zero/1.0/> ;
	vann:preferredNamespacePrefix   ":" ;
	vann:preferredNamespaceUri      "" ;
	owl:versionInfo					"1.0";
.

:hasAuthor rdf:type owl:ObjectProperty ;
    rdfs:domain :Initiative ;
    rdfs:range <http://example.org/map4scrutiny/core#Parliamentarian> . # TODO: Publish M4S


:hasContent rdf:type owl:ObjectProperty ,
             owl:FunctionalProperty ;
    rdfs:domain :Initiative ;
    rdfs:range :Content .


:hasLegislativeSession rdf:type owl:ObjectProperty ;
     rdfs:domain :Initiative ;
     rdfs:range ocd:sessioneLegislatura .


:hasLegislature rdf:type owl:ObjectProperty ,
            owl:FunctionalProperty ;
            rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( ocd:mandatoCamera
                                        ocd:sessioneLegislatura
                                        :Initiative
                                        :ParliamentaryGroup
                                        )
                        ] ;
            rdfs:range ocd:legislatura .


:originated rdf:type owl:ObjectProperty ;
    rdfs:domain :Initiative ;
    rdfs:range :Initiative .


:originatedFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :Initiative ;
    rdfs:range [ rdf:type owl:Class ;
                  owl:unionOf ( :EuropeanInitiative
                                :Initiative
                              )
                ] .


:hasParliamentaryGroup rdf:type owl:ObjectProperty ,
              owl:FunctionalProperty ;
     rdfs:domain :ParliamentaryGroupMembership ;
     rdfs:range :ParliamentaryGroup .


:hasParliamentaryGroupMembership rdf:type owl:ObjectProperty ;
    rdfs:domain ocd:mandatoCamera ;
    rdfs:range :ParliamentaryGroupMembership .


:hasParty rdf:type owl:ObjectProperty ,
             owl:FunctionalProperty ;
    rdfs:domain :ParliamentaryGroup ;
    rdfs:range :Party .


:hasProponent rdf:type owl:ObjectProperty ;
    rdfs:domain :Initiative ;
    rdfs:range [ rdf:type owl:Class ;
      owl:unionOf ( ocd:governo
                    <http://example.org/map4scrutiny/core#Parliamentarian>
                    :CitizenGroup
                    :Commission
                    :PAR
                    :ParliamentaryGroup
                    :RegionalLegislativeAssembly
                  )
    ] .

:hasTopic rdf:type owl:ObjectProperty ;
    rdfs:domain :Initiative ;
    rdfs:range :Topic .

#################################################################
#    Data properties
#################################################################

:hasIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://w3id.org/nfdi4ing/metadata4ing#identifier> ;
    rdf:type owl:FunctionalProperty .


:hasLink rdf:type owl:DatatypeProperty ;
    rdfs:domain :Content ;
    rdfs:range xsd:string .

:hasLocation rdf:type owl:DatatypeProperty ;
    rdfs:domain :RegionalLegislativeAssembly ;
    rdfs:range xsd:string .


:hasName rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
    rdfs:range xsd:string .

:hasParliamentaryName rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/name> ;
    rdfs:domain ocd:mandatoCamera ;
    rdfs:range xsd:string .

:hasText rdf:type owl:DatatypeProperty ;
    rdfs:domain :Content ;
    rdfs:range xsd:string .


:hasTitle rdf:type owl:DatatypeProperty ;
    rdfs:domain [ rdf:type owl:Class ;
                  owl:unionOf ( :Initiative
                                :Topic
                              )
                ] ;
    rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

:CitizenGroup rdf:type owl:Class ;
    rdfs:label "Citizen Group"@en ,
               "Grupo de Cidadãos"@pt .


:Commission rdf:type owl:Class ;
    rdfs:label "Comissão"@pt ,
               "Commission"@en .


:ConstitutionalRevisionProject rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:Content rdf:type owl:Class .


:DeliberationProject rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:Duty rdf:type owl:Class .


:EuropeanInitiative rdf:type owl:Class ;
    rdfs:subClassOf ocd:atto .

:Guest rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> .


:Initiative rdf:type owl:Class ;
    rdfs:subClassOf ocd:atto .


:LawProject rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:LawProposal rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:PAR rdf:type owl:Class ;
    rdfs:subClassOf <http://xmlns.com/foaf/0.1/Person> .


:ParliamentaryAppreciation rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .

:ParliamentaryGroup rdf:type owl:Class .

:ParliamentaryGroupMembership rdf:type owl:Class .

:ParliamentaryInquiry rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:Party rdf:type owl:Class ;
    rdfs:subClassOf <http://www.w3.org/ns/org#Organization> .

:PopularReferendumInitiative rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .

:Ratification rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .

:RegionalLegislativeAssembly rdf:type owl:Class .

:ResolutionProject rdf:type owl:Class ;
   rdfs:subClassOf :Initiative .

:ResolutionProposal rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .

:RulesOfProcedureProject rdf:type owl:Class ;
    rdfs:subClassOf :Initiative .


:Situation rdf:type owl:Class .

:Topic rdf:type owl:Class .
