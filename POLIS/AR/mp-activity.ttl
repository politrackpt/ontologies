@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix ocd: <http://dati.camera.it/ocd/> .
@prefix m4s: <https://purl.org/map4scrutiny-core#> .
@prefix schema:	<https://schema.org/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix polis-core: <http://purl.org/polis/ar/core#> .
@prefix polis-bio: <http://purl.org/polis/ar/biographic#> .
@prefix polis-ini: <http://purl.org/polis/ar/initiatives#> .
@prefix : <http://purl.org/polis/ar/mp-activity#> .

@base <http://purl.org/polis/ar/mp-activity#> .

:	
	a                           	<http://purl.org/vocommons/voaf#Vocabulary> , owl:Ontology ;
	dct:title                   	"Portuguese Political Structures Ontology";
	dct:description             	"";
	dct:creator                 	"Tiago Ribeiro de Sá Cruz", "João Miguel da Silva Lourenço";
	dct:contributor                 "Mariana Curado Malta", "João Bispo";
    dct:issued                 		""^^schema:Date;
	dct:license                 	<http://creativecommons.org/publicdomain/zero/1.0/> ;
	vann:preferredNamespacePrefix   "polis-mpact:" ;
	vann:preferredNamespaceUri      "http://purl.org/polis/ar/mp-activity#" ;
	owl:versionInfo					"1.0";
    dct:description                    """The objective of the POLIS ontology is to (...)""" ;
    dcterms:bibliographicCitation ""@en ;
    dcterms:created ""^^xsd:date ;
    dcterms:modified ""^^xsd:date ;
    dcterms:language "en", "pt" ;
.

#################################################################
#    Classes
#################################################################

:Request a owl:Class ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	rdfs:label "Request"@en, "Requerimento"@pt ;
	rdfs:comment "A request made by an MP."@en, "Uma requerimento feito por um MP."@pt ;
	rdfs:subClassOf ocd:richiestaParere .

:Inquiry a owl:Class ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	rdfs:label "Inquiry"@en, "Inquérito"@pt ;
	rdfs:comment "An inquiry made by an MP."@en, "Uma pergunta feita por um MP."@pt ;
	rdfs:subClassOf ocd:richiestaParere .

:PublicEntityType a owl:Class ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	rdfs:label "Public Entity Type"@en, "Tipo de Entidade Pública"@pt ;
	rdfs:comment "A type of public entity."@en, "Um tipo de entidade pública."@pt .

##################################################################
#    Object Properties
##################################################################

:toPublicEntityType a owl:ObjectProperty ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	rdfs:label "to Public Entity Type"@en, "para Tipo de Entidade Pública"@pt ;
	rdfs:comment "Indicates the public entity type where an MP made a requisition (request or inquiry)."@en, "Indica o tipo de entidade pública onde um MP fez um requerimento (requerimento ou pergunta)."@pt ;
	rdfs:domain ocd:richiestaParere ;
	rdfs:range :PublicEntityType .

##################################################################
#    Individuals
##################################################################

:AC a owl:NamedIndividual, :PublicEntityType ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	foaf:name "Central Administration"@en, "Administração Central"@pt ;
	rdfs:label "Central Administration"@en, "Administração Central"@pt ;
	rdfs:comment "A Central Administration."@en, "Uma Administração Central."@pt .

:AL a owl:NamedIndividual, :PublicEntityType ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	foaf:name "Local Administration"@en, "Administração Local"@pt ;
	rdfs:label "Local Administration"@en, "Administração Local"@pt ;
	rdfs:comment "A Local Administration."@en, "Uma Administração Local."@pt .

:AR a owl:NamedIndividual, :PublicEntityType ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	foaf:name "Assembly of the Republic"@en, "Assembleia da República"@pt ;
	rdfs:label "Assembly of the Republic"@en, "Assembleia da República"@pt ;
	rdfs:comment "The Assembly of the Republic is the national parliament of Portugal."@en, "A Assembleia da República é o parlamento nacional de Portugal."@pt .

:EI a owl:NamedIndividual, :PublicEntityType ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	foaf:name "Independent Entities"@en, "Entidades Independentes"@pt ;
	rdfs:label "Independent Entities"@en, "Entidades Independentes"@pt ;
	rdfs:comment "Independent Entities."@en, "Entidades Independentes."@pt .

:RA a owl:NamedIndividual, :PublicEntityType ;
	rdfs:isDefinedBy <http://purl.org/polis/ar/mp-activity#> ;
	foaf:name "Autonomous Regions"@en, "Regiões Autónomas"@pt ;
	rdfs:label "Autonomous Regions"@en, "Regiões Autónomas"@pt ;
	rdfs:comment "Autonomous Regions"@en, "Regiões Autónomas"@pt .